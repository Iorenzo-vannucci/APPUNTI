# vim: ft=dockerfile
# 2021-12-02 09:00 Rome time 
#
# This Docker Image embeds all the necessary python libraries and files for the CyberChallenge student.
# In particular, the following are included:
#   * Python3.9
#   * Jupyter tutorials
#   * ChipWhisperer
#   * Matplotlib
#   * Pandas
#   * RPYC
#   * N Jupyter tutorials Tutorials
#   * RPYC client python script (client.py)
# 
# This container must be isntructed (at 'docker run' time) with the list of all available CW devices.
# 
# README:
# Python >=3.9 is needed for typing annotations, see https://docs.python.org/3/whatsnew/3.9.html


### DOCKER BUILD ###
# Every operation from now on is executed @ "docker build" time
FROM ubuntu:20.04


################## ENV ##################

# # Should reflect the host IDs
ENV UID=1000
ENV GID=1000

# The container's user [cw0 - cw39]
ENV TZ=Europe/Rome
ENV USER_NAME=cc_tutorials

ENV PATH="/home/$USER_NAME/.local/bin:${PATH}"


################## RUN ##################

# Essentials
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone
RUN apt-get update && apt-get install -y \
    # netcat \
    # nano \
    # usbutils \
    # udev \
    python3.9 \
    python3-pip \
    # python3-venv \
    # libusb-dev \
    # make \
    git
# avr-libc \
# gcc-avr \
# gcc-arm-none-eabi


# Create unprivileged user
RUN useradd -r --uid $UID --user-group --create-home --home-dir /home/$USER_NAME --shell /bin/bash $USER_NAME
WORKDIR /home/$USER_NAME/
# Switch to unprivileged user
USER $USER_NAME

# Download Python libs and Chipwhisperer repo
COPY --chown=$USER_NAME:$USER_NAME client_requirements.txt /home/$USER_NAME/
RUN python3.9 -m pip install -r client_requirements.txt
# Copy cyberchallenge library and install it
COPY --chown=$USER_NAME:$USER_NAME ./cyberchallenge_client /home/$USER_NAME/cyberchallenge_client/
RUN python3.9 -m pip install /home/$USER_NAME/cyberchallenge_client/dist/cyberchallenge_client-0.0.1-py3-none-any.whl
# Copy tutorials folder
COPY --chown=$USER_NAME:$USER_NAME ./tutorials/tutorials/ /home/$USER_NAME/tutorials/
# Copy challenges folder
COPY --chown=$USER_NAME:$USER_NAME ./challenges/ /home/$USER_NAME/challenges/
# Cleanup
RUN rm /home/${USER_NAME}/client_requirements.txt
RUN rm -rf /home/${USER_NAME}/cyberchallenge_client

################## CMD/ENTRYPOINT #####################
# CMD bash
CMD jupyter notebook --port=8888 --no-browser --ip=0.0.0.0
